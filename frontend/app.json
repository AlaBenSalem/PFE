{
  "expo": {
    "name": "SmartIrrig",
    "slug": "smartirrig-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#15803d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartirrig.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.smartirrig.app",
      "versionCode": 5,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#22c55e"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro"
    },
    "scheme": "smartirrig",
    "extra": {
      "eas": {
        "projectId": "1cab0d89-5c04-4ef6-b035-d02b99f7bb85"
      }
    },
    "owner": "mohamed9543",
    "plugins": [
  [
    "@react-native-google-signin/google-signin",
    {
      "googleServicesFile": "./google-services.json",
      "iosUrlScheme": "com.googleusercontent.apps.861346189775-jt0kp72jduhpgkjnnupjboosdchu11td"
    }
  ],
  [
    "expo-speech-recognition",
    {
      "microphonePermission": "Autoriser SmartIrrig à utiliser le microphone pour la reconnaissance vocale.",
      "speechRecognitionPermission": "Autoriser SmartIrrig à reconnaître votre voix.",
      "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
    }
  ],
  [
    "expo-notifications",
    {
      "color": "#16a34a"
    }
  ]
]
  }
}