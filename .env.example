# Single source-of-truth env file (repo root).
# Copy to `.env` (this file is ignored by git via .gitignore).
#
# Frontend (Expo): only variables prefixed with EXPO_PUBLIC_ are visible in the app.
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000

# Backend
PORT=5000
NODE_ENV=development

# MongoDB (primary)
MONGODB_URI=mongodb://127.0.0.1:27017/smartirrig

# Optional local/Compass connection
# MONGODB_LOCAL_URI=mongodb://127.0.0.1:27017/
# ENABLE_LOCAL_MONGODB=true
# MONGODB_LOCAL_DB=smartirrig

# Security
JWT_SECRET=change_me

# Admin auto-provisioning
ADMIN_EMAIL=admin@smartirrig.com
ADMIN_PASSWORD=change_me
ADMIN_NAME=Administrateur

# Admin notifications (message/report emails)
ADMIN_NOTIFY_EMAIL=your_admin_email@gmail.com
ENABLE_ADMIN_MESSAGE_EMAIL=true

# Weather
OPENWEATHER_API_KEY=change_me

# Email
# Provider selection: auto | resend | gmail
EMAIL_PROVIDER=gmail
# Log reset codes to console (never enable in production)
LOG_RESET_CODES=false

# Gmail (nodemailer) — use an App Password, not your account password
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_USER=your_service_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Resend (alternative provider)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=SmartIrrig <onboarding@resend.dev>

# Google Auth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id
GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id

# ET0 validation bounds (FAO-56)
ET0_MIN_VALID=0.1
ET0_MAX_VALID=30
