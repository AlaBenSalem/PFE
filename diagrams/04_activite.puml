@startuml SmartIrrig_Activite

skinparam monochrome true
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ArrowColor #333333
skinparam ActivityBorderColor #333333
skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityDiamondBackgroundColor #eeeeee

title SmartIrrig — Diagramme d'Activités

start

:Ouvrir l'application SmartIrrig;

if (Possède un compte ?) then (Non)
  :S'inscrire;
endif

if (Connexion Google ?) then (Oui)
  :Authentification via Google;
else (Non)
  :Saisir email et mot de passe;
  if (Identifiants valides ?) then (Non)
    :Afficher erreur;
    stop
  endif
endif

:Accéder au tableau de bord;

if (Profil Administrateur ?) then (Oui)

  :Consulter les statistiques globales;

  fork
    :Gérer les utilisateurs;
  fork again
    :Gérer la base de données Kc;
  end fork

else (Non — Utilisateur)

  if (Aucune culture enregistrée ?) then (Oui)
    :Ajouter une culture\n(nom, sol, surface, système d'irrigation);
  endif

  :Choisir une fonctionnalité;

  fork
    :Irrigation\n(consulter besoins, enregistrer);
  fork again
    :Fertilisation\n(consulter calendrier, enregistrer);
  fork again
    :Assistant IA\n(poser une question par texte ou voix);
  end fork

  :Consulter les notifications;

endif

:Se déconnecter;

stop

@enduml
