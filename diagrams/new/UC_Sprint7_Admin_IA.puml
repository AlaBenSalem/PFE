@startuml UC_Sprint7_Admin_IA
title UC — Sprint 7 : Interface Admin & Assistant IA
skinparam backgroundColor white
skinparam defaultFontName Arial
skinparam monochrome true
skinparam shadowing false

' ── Taille pour impression ──────────────

skinparam defaultFontSize 16
skinparam usecaseFontSize 16
skinparam actorFontSize 18
skinparam packageFontSize 18
skinparam noteFontSize 14
skinparam ArrowFontSize 14
skinparam usecaseBorderThickness 2
skinparam actorBorderThickness 2.5
skinparam ArrowThickness 2
skinparam nodesep 60
skinparam ranksep 80


left to right direction

actor Utilisateur as U
actor Administrateur as A
actor "Groq API\n(LLM)" as Groq
actor "ElevenLabs\nTTS" as TTS

rectangle "Sprint 7 — Admin & Chatbot IA" {
  usecase "Envoyer un message texte" as UC1
  usecase "Dicter un message vocal" as UC2
  usecase "Transcrire la voix en texte" as UC2a
  usecase "Écouter la réponse (TTS)" as UC3
  usecase "Changer la langue du chat" as UC4
  usecase "Gérer les utilisateurs\n(CRUD)" as UC5
  usecase "Consulter le tableau de bord\nadmin (statistiques globales)" as UC6
  usecase "Gérer la base Kc\n(KCReference)" as UC7
  usecase "Consulter les messages\nreçus" as UC8
  usecase "Répondre à un message" as UC8a
}

U --> UC1
UC1 --> Groq
U --> UC2
UC2 ..> UC2a : <<include>>
U --> UC3
UC3 --> TTS
U --> UC4
A --> UC5
A --> UC6
A --> UC7
A --> UC8
UC8 ..> UC8a : <<extend>>
@enduml
