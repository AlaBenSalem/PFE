@startuml UC_Sprint2_Meteo_Dashboard
title UC — Sprint 2 : Intégration Météo & Tableau de Bord
skinparam backgroundColor white
skinparam defaultFontName Arial
skinparam monochrome true
skinparam shadowing false

' ── Taille pour impression ──────────────

skinparam defaultFontSize 16
skinparam usecaseFontSize 16
skinparam actorFontSize 18
skinparam packageFontSize 18
skinparam noteFontSize 14
skinparam ArrowFontSize 14
skinparam usecaseBorderThickness 2
skinparam actorBorderThickness 2.5
skinparam ArrowThickness 2
skinparam nodesep 60
skinparam ranksep 80


left to right direction

actor Utilisateur as U
actor "OpenWeather\nAPI" as OW

rectangle "Sprint 2 — Météo & Dashboard" {
  usecase "Consulter la météo actuelle" as UC1
  usecase "Récupérer ET₀\n(Penman-Monteith)" as UC1a
  usecase "Consulter les prévisions\n(5 jours)" as UC2
  usecase "Rechercher une ville" as UC3
  usecase "Consulter le tableau de bord\n(stats réelles)" as UC4
}

U --> UC1
UC1 ..> UC1a : <<include>>
UC1 --> OW
UC2 --> OW
U --> UC2
U --> UC3
U --> UC4
@enduml