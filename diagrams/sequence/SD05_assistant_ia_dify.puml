@startuml SD05_Assistant_IA

skinparam monochrome true
skinparam shadowing false
skinparam defaultFontSize 15
skinparam sequenceParticipantFontSize 15
skinparam sequenceActorFontSize 15
skinparam sequenceMessageFontSize 13
skinparam sequenceParticipantPadding 15
skinparam sequenceActorPadding 10
skinparam ArrowThickness 2

title SD05 — Assistant IA (Groq + ElevenLabs TTS)

actor "Utilisateur" as U
participant "App Mobile" as App
participant "aiRoutes\n(Express)" as API
participant "weatherService" as WS
database "MongoDB" as DB
participant "Groq API" as Groq
participant "ElevenLabs TTS" as EL

== Envoi d'un message ==

alt Message texte
  U -> App : Tape son message
else Message vocal
  U -> App : Appuie sur le micro
  App -> App : Reconnaissance vocale multilingue
end

App -> API : POST /api/ai/chat { message, conversationId, city }
API -> DB : Culture.find + Irrigation.find + Fertilisation.find
DB --> API : contexte utilisateur
API -> WS : getLiveWeather(city)
WS --> API : { et0, temperature, humidity }
API -> API : buildUserContext() + detectLanguage()
API -> Groq : POST /openai/v1/chat/completions\n{ systemPrompt + contexte + historique }
Groq --> API : reponse texte
API --> App : { answer, conversationId }
App --> U : Reponse affichee

== Synthese vocale ==

alt Langue arabe
  App -> API : POST /api/ai/tts { text }
  API -> EL : POST /text-to-speech { eleven_multilingual_v2 }
  EL --> API : audio MP3
  API --> App : Buffer MP3
  App --> U : Reponse lue (ElevenLabs)
else Autres langues
  App -> App : SpeechSynthesis natif
  App --> U : Reponse lue (voix systeme)
end

== Changement de langue ==

U -> App : Change langue (AR/FR/EN/TR)
App -> App : Reset conversation
App --> U : Nouveau fil dans la langue choisie

@enduml