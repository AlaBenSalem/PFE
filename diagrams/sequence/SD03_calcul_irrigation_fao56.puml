@startuml SD03_Calcul_Irrigation_FAO56

skinparam monochrome true
skinparam shadowing false
skinparam defaultFontSize 15
skinparam sequenceParticipantFontSize 15
skinparam sequenceActorFontSize 15
skinparam sequenceMessageFontSize 13
skinparam sequenceParticipantPadding 15
skinparam sequenceActorPadding 10
skinparam ArrowThickness 2

title SD03 — Calcul Irrigation FAO-56

actor "Utilisateur" as U
participant "App Mobile" as App
participant "irrigationRoutes\n(Express)" as API
participant "weatherService" as WS
participant "OpenWeather API" as OW
database "MongoDB" as DB

== Chargement Irrigation ==

U -> App : Ouvre onglet "Irrigation"
App -> API : GET /api/irrigation/needs
API -> DB : Culture.find({ userId }).populate('kc')
DB --> API : cultures avec Kc
API -> WS : getLatestWeather(city)
alt Cache valide (< 30 min)
  WS --> API : meteo en cache
else Cache expire
  WS -> OW : GET /data/2.5/weather?q={city}
  OW --> WS : { temp, humidity, wind, ... }
  WS -> WS : Calcul ET0 (Penman-Monteith FAO-56)
  WS -> DB : Weather.create({ et0, ...data })
  WS --> API : meteo fraiche + ET0
end

loop Pour chaque culture
  API -> API : ETc = ET0 x Kc_actuel
  API -> API : Volume = ETc x surface / 1000
  API -> API : Volume_reel = Volume / efficacite(mode)
  API -> API : Duree = Volume_reel x 1000 / Debit_total
  API -> DB : Irrigation.findOne({ cultureId })
  DB --> API : derniere irrigation + prochaine date
end

API --> App : { etcValues, volumes, durations, nextDates }
App --> U : Recommandations par culture

== Enregistrement Irrigation ==

U -> App : Selectionne culture + mode, valide
App -> API : POST /api/irrigation { cultureId, volume,\n  duration, mode, date, frequenceJours }
API -> DB : Irrigation.create({ ...data })
API -> DB : Culture.findByIdAndUpdate({ kcActuel, stadeActuel })
API --> App : 201 { success, data }
App --> U : Irrigation enregistree

== Historique ==

U -> App : Ouvre onglet "Historique"
App -> API : GET /api/irrigation/history?limit=50
API -> DB : Irrigation.find({ userId }).sort({ date: -1 })
API --> App : { data: [...irrigations] }
App --> U : Liste chronologique

@enduml